# Database connection url
# Local Docker Postgres: postgresql://postgres:postgres@localhost:5432/freightshare
# Local SQLite fallback: sqlite:///./freightshare.db (geographical spatial queries will not be available in sqlite mode)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/freightshare

# Redis Cache and Celery Message Broker
REDIS_URL=redis://localhost:6379/0

# Firebase Auth Configuration
FIREBASE_PROJECT_ID=freightshare-prod
# Set to 'true' to allow mock logins using email/role during development without requiring real Firebase ID tokens
LOCAL_DEV_MODE=true

# JWT signing (for fallback authentication)
JWT_SECRET=428f5efd28e7bb7f9bdfa95c3453a2ef9b1fbf4148b3b64cfc418721c0ad5d45
JWT_ALGORITHM=HS256

# Third-party API integrations
GOOGLE_MAPS_API_KEY=your_google_maps_routes_api_key_here
# LLM key for Anthropic Claude / OpenAI GPT-4o mini matches summary explanation
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
